{
	"name": "rokke/contracts",
	"description": "Rokke Contracts – Public platform interfaces and shared vocabulary for the Rokke ecosystem.",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Fernando Duarte",
			"email": "fduarte@rokke.dev"
		}
	],
	"keywords": [
		"contracts",
		"interfaces",
		"platform",
		"php"
	],
	"homepage": "https://rokke.dev",
	"support": {
		"issues": "https://github.com/rokke-php/contracts/issues",
		"source": "https://github.com/rokke-php/contracts"
	},
	"version": "0.3.0",
	"require": {
		"php": ">=8.4",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.64",
		"phpstan/phpstan": "^1.12 || ^2.0"
	},
	"autoload": {
		"psr-4": {
			"Rokke\\Contracts\\": "src/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true,
		"preferred-install": "dist",
		"allow-plugins": {}
	},
	"scripts": {
		"lint": "php-cs-fixer fix --dry-run --diff --verbose",
		"lint:fix": "php-cs-fixer fix",
		"analyse": "phpstan analyse --memory-limit=2G",
		"check": [
			"@lint",
			"@analyse"
		]
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
